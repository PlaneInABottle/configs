{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "autoupdate": true,
  "default_agent": "plan",
  "instructions": [
    "./OPENCODE.md"
  ],
  "permission": {
    "doom_loop": "ask",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "agent-browser*": "allow",
      "cat*": "allow",
      "cargo test*": "allow",
      "curl*127.0.0.1*": "allow",
      "curl*localhost*": "allow",
      "date*": "allow",
      "cut*": "allow",
      "diff*": "allow",
      "echo*": "allow",
      "file*": "allow",
      "find*": "allow",
      "git *": "allow",
      "git push*": "ask",
      "git pull*": "ask",
      "git rebase*": "ask",
      "git reset --hard*": "ask",
      "git reset --*": "ask",
      "git clean*": "ask",
      "git stash*": "ask",
      "git stash drop*": "ask",
      "git checkout -f*": "ask",
      "git checkout --*": "ask",
      "git rm*": "ask",
      "git mv*": "ask",
      "git commit*": "ask",
      "git merge*": "ask",
      "git merge-base*": "allow",
      "git merge-tree*": "allow",
      "gh *": "allow",
      "gh pr create*": "ask",
      "gh pr merge*": "ask",
      "gh issue create*": "ask",
      "gh issue close*": "ask",
      "gh repo create*": "ask",
      "gh repo delete*": "ask",
      "gh secret*": "ask",
      "gh run*": "ask",
      "go test*": "allow",
      "grep*": "allow",
      "head*": "allow",
      "jq*": "allow",
      "less*": "allow",
      "ls*": "allow",
      "make*": "allow",
      "more*": "allow",
      "nl*": "allow",
      "node --help*": "allow",
      "node --version*": "allow",
      "node -v*": "allow",
      "npm*": "allow",
      "python *": "deny",
      "python3 *": "allow",
      "bun *": "allow",
      "bun remove*": "ask",
      "bunx *": "allow",
      "bunx remove*": "ask",
      "bunx uninstall*": "ask",
      "command -v*": "allow",
      "pm2 *": "allow",
      "printenv*": "allow",
      "printf*": "allow",
      "pwd": "allow",
      "test*": "allow",
      "pytest*": "allow",
      "rg*": "allow",
      "sort*": "allow",
      "stat*": "allow",
      "sed -n*": "allow",
      "sed -i*": "deny",
      "sleep*": "allow",
      "tail*": "allow",
      "tree*": "allow",
      "du*": "allow",
      "lsof*": "allow",
      "ps*": "allow",
      "psql*localhost*": "allow",
      "type*": "allow",
      "uname*": "allow",
      "wc*": "allow",
      "which*": "allow",
      "true*": "allow",
      "break*": "allow",
      "seq*": "allow",
      "uv*": "allow",
      "hurl*": "allow",
      "docker*": "allow",
      "docker rm*": "ask",
      "docker system prune*": "ask",
      "kubectl delete*": "ask",
      "terraform destroy*": "ask",
      "eslint*": "allow",
      "prettier*": "allow",
      "biome*": "allow",
      "ruff*": "allow",
      "pylint*": "allow",
      "shellcheck*": "allow",
      "vitest*": "allow",
      "jest*": "allow",
      "cypress*": "allow",
      "playwright*": "allow",
      "cargo*": "allow",
      "rustc*": "allow",
      "go build*": "allow",
      "cmake*": "allow",
      "htop*": "allow",
      "top*": "allow",
      "df*": "allow",
      "free*": "allow",
      "netstat*": "allow",
      "gitk*": "allow",
      "tig*": "allow",
      "kill*": "allow",
      "npx*": "allow",
      "npx remove*": "ask",
      "npx uninstall*": "ask",
      "pnpm*": "allow",
      "pnpm remove*": "ask",
      "yarn*": "allow",
      "yarn remove*": "ask",
      "watchexec*": "allow",
      "entr*": "allow",
      "render*": "allow",
      "whereis*": "allow"
    },
    "edit": {
      "*": "ask"
    },
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": {
      "*": "allow"
    },
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "sim-mcp_remove_blocks": "ask",
    "sim-mcp_remove_edge": "ask",
    "sim-mcp_remove_variable": "ask",
    "sim-mcp_delete_skill": "ask",
    "sim-mcp_replace_workflow_state": "ask",
    "sim-mcp_update_block_name": "ask",
    "sim-mcp_toggle_block_enabled": "ask",
    "sim-mcp_update_block_parent": "ask",
    "sim-mcp_update_subblock": "ask",
    "sim-mcp_update_subflow": "ask",
    "sim-mcp_update_skill": "ask",
    "sim-mcp_execute_workflow": "ask",
    "sim-mcp_upsert_custom_tools": "ask",
    "context7_*": "allow",
    "livekit-docs-mcp_*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true,
      "environment": {}
    },
    "sim-mcp": {
      "type": "local",
      "command": [
        "node",
        "{env:SIM_MCP_LOCATION}",
        "--server"
      ],
      "enabled": true,
      "environment": {
        "SIM_API_BASE_URL": "{env:SIM_API_BASE_URL_REMOTE}",
        "SIM_API_KEY": "{env:SIM_API_KEY_REMOTE}"
      }
    },
    "livekit-docs-mcp": {
      "type": "remote",
      "url": "https://docs.livekit.io/mcp",
      "enabled": true
    }
  }
}
