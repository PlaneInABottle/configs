{
  "providers": {
    "llama.cpp": {
      "baseUrl": "http://127.0.0.1:8080/v1",
      "api": "openai-completions",
      "apiKey": "local",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false,
        "supportsUsageInStreaming": false,
        "maxTokensField": "max_tokens"
      },
      "models": [
        {
          "id": "gemma",
          "name": "Gemma 4 12B QAT Q4 local",
          "input": [
            "text",
            "image"
          ],
          "contextWindow": 8192,
          "maxTokens": 2048,
          "reasoning": true,
          "thinkingLevelMap": {
            "off": "off",
            "minimal": "minimal",
            "low": "low",
            "medium": "medium",
            "high": "high",
            "xhigh": "xhigh"
          }
        }
      ]
    }
  }
}
