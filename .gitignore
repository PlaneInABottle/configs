# Removed duplicate patterns - using simple filename patterns below

# Kitty - Session and temporary files
kitty/.config/kitty/sessions/

# General exclusions
__pycache__/
*.py[cod]
*.log
*.tmp
*.cache
*~
.DS_Store
.credentials.json
.update.lock
youtube-downloads/

# Environment variables
.env
.secrets/
.serena/

# OpenCode - Exclude local environment and runtime files
